NEXT_PUBLIC_SITE_URL=https://cothecoconutcompany.com

# Google Search Console verification meta value.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification meta value.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Google Analytics 4 measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Firebase Web App configuration.
# Firebase Console > Project settings > General > Your apps > Web app > SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK.
# Firebase Console > Project settings > Service accounts > Generate new private key.
# Preferred: paste the whole service account JSON as a single-line value in Vercel.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternative to FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Admin OS.
ADMIN_BASE_PATH=/control-center
ADMIN_EMAIL=
ADMIN_NAME=.CO Admin
ADMIN_ROLE=Super Admin

# Legacy Supabase values are no longer used for auth after Firebase integration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
