NEXT_PUBLIC_SITE_URL=https://cothecoconutcompany.com

# Future AWS backend API. Leave empty until the dev API has been deployed and verified.
NEXT_PUBLIC_DOTCO_API_BASE_URL=

# Google Search Console verification meta value.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification meta value.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Google Analytics 4 measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Firebase Web App configuration.
# Firebase Console > Project settings > General > Your apps > Web app > SDK setup and configuration.
# Required for Firebase Authentication: API key, auth domain, project ID, and app ID.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional Firebase Web values. Storage is not required by the CMS.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK.
# Firebase Console > Project settings > Service accounts > Generate new private key.
# Preferred: paste the whole service account JSON as a single-line value in Vercel.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternative to FIREBASE_SERVICE_ACCOUNT_JSON. Configure one Admin SDK method, not both.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional; the storage-free CMS does not use this value.
FIREBASE_STORAGE_BUCKET=

# Admin OS.
ADMIN_BASE_PATH=/control-center
ADMIN_EMAIL=
ADMIN_NAME=.CO Admin
ADMIN_ROLE=Super Admin
ADMIN_SESSION_SECRET=
SESSION_COOKIE_NAME=co_session
SESSION_MAX_AGE_DAYS=7

# No REVALIDATION_SECRET is required. CMS revalidation runs only inside authenticated server actions.

# Abuse protection.
# reCAPTCHA v3 is active when both values are configured.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Optional Firebase App Check key for a future stricter client enforcement rollout.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# Legacy Supabase values are no longer used for auth after Firebase integration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AWS backend foundation. These values are generated by CDK outputs per environment.
# Do not put AWS credentials in browser-visible variables.
DOTCO_ENV=dev
DOTCO_AWS_REGION=ap-south-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_ISSUER=
COMMERCE_TABLE_NAME=dotco-dev-commerce
CONTENT_TABLE_NAME=dotco-dev-content
AUDIT_TABLE_NAME=dotco-dev-audit
