{
  "name": "co-coconut-company",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "npm --prefix packages/contracts test && npm --prefix backend test && npm --prefix infra test",
    "backend:typecheck": "npm --prefix packages/contracts run typecheck && npm --prefix backend run typecheck",
    "infra:synth": "npm --prefix infra run synth",
    "start": "next start",
    "lint": "eslint .",
    "optimize:images": "node scripts/optimize-images.js",
    "assets:optimize": "node scripts/optimize-assets.mjs",
    "assets:transparent": "node scripts/create-transparent-assets.mjs",
    "favicons:generate": "node scripts/generate-favicons.mjs",
    "media:generate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/generate-media-library.ts",
    "media:sync": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/sync-local-media-library.ts",
    "firestore:backup": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/firestore-backup.ts",
    "firestore:restore": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/firestore-restore.ts",
    "firebase:bootstrap-admin": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/bootstrap-admin.ts",
    "firebase:audit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/firebase-audit.ts",
    "migrate:firebase:dry-run": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/migrate-firebase.ts dry-run",
    "migrate:firebase:dev": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/migrate-firebase.ts dev",
    "verify:migration:dev": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify-migration.ts",
    "godaddy:dns:check": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/godaddy-dns-sync.ts",
    "godaddy:dns:apply": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/godaddy-dns-sync.ts --apply"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1085.0",
